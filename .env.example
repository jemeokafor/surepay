# SurePay Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Supabase Configuration
# ============================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Paystack Configuration
# ============================================
# Get from Paystack Dashboard
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_APP_URL=https://surepay.link
NEXT_PUBLIC_APP_NAME=SurePay

# ============================================
# API Configuration
# ============================================
# FastAPI backend URL (for webhooks)
API_URL=http://localhost:8000
WEBHOOK_BASE_URL=https://your-domain.com/api/webhooks

# ============================================
# Email Configuration (Resend/Postmark)
# ============================================
RESEND_API_KEY=re_NhihqPVs_NqK5fws34VjGweSRPddhUutM
EMAIL_FROM=noreply@surepay.link
EMAIL_FROM_NAME=SurePay

# ============================================
# Admin Configuration
# ============================================
DEFAULT_ADMIN_EMAIL=admin@surepay.link
DEFAULT_ADMIN_PASSWORD=Admin123!

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=your-sentry-dsn

# ============================================
# Security & Rate Limiting
# ============================================
# Risk cap for transactions (NGN)
RISK_CAP_AMOUNT=250000

# ============================================
# Development Settings
# ============================================
NODE_ENV=development
DEBUG=true
